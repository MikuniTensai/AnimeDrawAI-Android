rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===== COMMUNITY FEATURES =====
    
    // Community posts - public read, owner write/delete
    match /community_posts/{postId} {
      allow read: if true; // Anyone can view community posts
      
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.size() <= 15; // Limit fields
      
      allow update: if request.auth != null
                    && (
                      // Owner can update own post
                      request.auth.uid == resource.data.userId
                      // Anyone can increment likes/downloads/views
                      || (!request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['userId', 'username', 'imageUrl', 'prompt', 'workflow', 'createdAt'])
                          && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['likes', 'downloads', 'views', 'reportCount', 'isReported']))
                    );
      
      allow delete: if request.auth != null 
                    && request.auth.uid == resource.data.userId;
    }

    // Workflow Stats - Public Read, Auth Write (for increments)
    match /workflow_stats/{workflowId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Leaderboards - Public Read (Generated by Cloud Functions)
    match /leaderboards/{documentId} {
      allow read: if true;
      allow write: if false; // Only written by Admin SDK
    }
    
    // User likes tracking - private per user
    match /user_likes/{userId}/posts/{postId} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId;
    }
    
    // User profiles - public read, owner write
    match /user_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId;
    }
    
    // User Subscription Data
    match /news/{document} {
      allow read: if true;
      allow write: if true; // Temporarily allow write for seeding
    }
    
    match /users/{userId} {
      // Allow read: Public read for logged in users (needed for referral lookup)
      allow read: if request.auth != null;
      // Allow create/update: Owner can update, plus transactions for referrals
      allow create, update: if request.auth != null; 
      // ideally we restrict writes more, but for MVP this enables the features
    }

    // --- NEW ENGAGEMENT FEATURES ---
    
    // Referral Logs - Check for fraud
    match /referral_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    // Redeem Codes - check validity
    match /redeem_codes/{codeId} {
      allow read, update: if request.auth != null;
    }
    
    match /generation_limits/{userId} {
      // Includes: dailyGenerations, maxDailyLimit, bonusGenerations, subscriptionType
      // More Feature: moreEnabled, moreRequestStatus
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Characters - private per user
    match /characters/{characterId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource == null);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Character Chats - private per user
    match /characterChats/{chatId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource == null);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // ===== LEGACY =====
    
    // Visions collection (existing)
    match /visions/{vision} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // App Settings - Public Read (for Welcome Message)
    match /app_settings/{document} {
      allow read: if true;
      allow write: if false; // Admin only via Console
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
